    <owl:NamedIndividual rdf:about="#SentenceEmbeddings">
        <rdf:type rdf:resource="#AdvancedConcept"/>
        <el:conceptName>Sentence and Document Embeddings</el:conceptName>
        <el:conceptDescription>Sentence-BERT, contrastive learning, semantic similarity — embedding entire sentences into dense vectors used in retrieval systems.</el:conceptDescription>
        <el:difficultyScore rdf:datatype="xsd:integer">6</el:difficultyScore>
        <el:abstractionLevel>Advanced</el:abstractionLevel>
        <el:typicalStudyHours rdf:datatype="xsd:integer">25</el:typicalStudyHours>
