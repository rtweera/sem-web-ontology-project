<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology/"
     xml:base="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:ai-ontology="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology">
        <rdfs:comment>Ontology of learning AI</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#canApplyFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#canApplyFor">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#needKnowldgeOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Career_Role"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#canUnderstand -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#canUnderstand">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#suitableForLevel"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Knowledge_Level"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Learning_Resource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>This level (domain) user can understand this (range) material</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#hasPrerequisite -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#hasPrerequisite">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#isPrerequisiteFor"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Foundational_Subject"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Foundational_Subject"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>Links one AI_Subfield to another (e.g., Neural Networks hasPrerequisite Linear Algebra).</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#isPrerequisiteFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#isPrerequisiteFor">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#isRecommendedResourceOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#isRecommendedResourceOf">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#recommendedResource"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#isToolOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#isToolOf">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#usesTool"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#needKnowldgeOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#needKnowldgeOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Career_Role"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#recommendedResource -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#recommendedResource">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Learning_Resource"/>
        <rdfs:comment>Links an AI_Subfield to a Learning_Resource.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#relatedTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#relatedTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#requiresKnowledgeLevel -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#requiresKnowledgeLevel">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Learning_Resource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Knowledge_Level"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#requiresSkill -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#requiresSkill">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Career_Role"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Skill_and_Tool"/>
        <rdfs:comment>Links a Career_Role to a Skill_and_Tool.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#suitableForLevel -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#suitableForLevel">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Learning_Resource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Knowledge_Level"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#suitedForTrait -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#suitedForTrait">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Career_Role"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Learner_Trait"/>
        <rdfs:comment>Links a Career_Role or AI_Subfield to a Learner_Trait.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#usesTool -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#usesTool">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Skill_and_Tool"/>
        <rdfs:comment>Links an AI_Subfield to a Skill_and_Tool (e.g., Computer Vision usesTool PyTorch).</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#averageSalary -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#averageSalary">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Career_Role"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Expected compensation for a role.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#courseDurationHours -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#courseDurationHours">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Online_Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#difficultyLevel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#difficultyLevel">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Rate a subfield from 1 to 10.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#isOpenSource -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#isOpenSource">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Skill_and_Tool"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#resourceURL -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#resourceURL">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Learning_Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment>The link to a learning resource.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#hasPrerequisite"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Foundational_Subject"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#usesTool"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Skill_and_Tool"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Career_Role"/>
        <rdfs:comment xml:lang="en">The specific areas of study.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Academia -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Academia">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Career_Role"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Industry"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Analytical_Thinker -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Analytical_Thinker">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Learner_Trait"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Book -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Book">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Learning_Resource"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Calculus -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Calculus">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Mathematics"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Career_Role -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Career_Role">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#averageSalary"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Learner_Trait"/>
        <rdfs:comment xml:lang="en">The jobs available in the industry.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Cloud_Platform -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Cloud_Platform">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Skill_and_Tool"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Computer_Science -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Computer_Science">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Foundational_Subject"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Computer_Vision -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Computer_Vision">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Data_Structures -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Data_Structures">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Computer_Science"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Deep_Learning_Framework -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Deep_Learning_Framework">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Skill_and_Tool"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Documentation -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Documentation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Learning_Resource"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Expert_Systems -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Expert_Systems">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Foundational_Subject -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Foundational_Subject">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#hasPrerequisite"/>
                <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Foundational_Subject"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Foundations needed for AI subjects</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Fuzzy_Logic -->

    <owl:Class rdf:about="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#Fuzzy_Logic">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ravindu/ontologies/2026/1/ai-ontology#AI_Subfield"/>
    </owl:Class>
    


